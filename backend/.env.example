# ── 阿里云 DashScope（千问）──────────────────────────────────
DASHSCOPE_API_KEY=sk-your-dashscope-api-key
QWEN_MODEL=qwen-max

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── PostgreSQL ───────────────────────────────────────────────
DATABASE_URL=postgresql://aiuser:aipass@localhost:5432/aiassistant

# ── Java 内部服务 ─────────────────────────────────────────────
JAVA_BASE_URL=http://your-java-service:8080
JAVA_AUTH_URL=http://your-java-auth-service:8080

# ── JWT ──────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production

# ── 应用 ─────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO

# ── 开发调试 ──────────────────────────────────────────────────
# 设为 true 时跳过所有权限验证，使用内置 mock 用户（拥有全部权限）
# 生产环境务必删除此行或设为 false
DEV_SKIP_AUTH=true
